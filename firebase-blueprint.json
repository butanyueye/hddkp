{
  "entities": {
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "A single entry in the global leaderboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user" },
        "name": { "type": "string", "description": "The display name of the user" },
        "score": { "type": "integer", "description": "The high score achieved" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the score was achieved" },
        "avatarId": { "type": "string", "description": "The ID of the character avatar" },
        "titleId": { "type": "string", "description": "The ID of the equipped title" },
        "frameId": { "type": "string", "description": "The ID of the equipped avatar frame" },
        "entranceEffectId": { "type": "string", "description": "The ID of the equipped entrance effect" }
      },
      "required": ["userId", "name", "score", "timestamp"]
    },
    "UserStats": {
      "title": "UserStats",
      "description": "Individual user statistics and progress",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user" },
        "name": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "description": "The email of the user" },
        "highScore": { "type": "integer", "description": "The user's personal best score" },
        "totalGames": { "type": "integer", "description": "Total number of games played" },
        "diamonds": { "type": "integer", "description": "Total diamonds collected" },
        "inventory": { 
          "type": "object", 
          "description": "Purchased items and their counts",
          "properties": {
            "shield": { "type": "integer" },
            "magnet": { "type": "integer" },
            "doubleScore": { "type": "integer" },
            "dash": { "type": "integer" }
          }
        },
        "achievements": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked achievements" },
        "unlockedCharacters": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked character IDs" },
        "selectedTitle": { "type": "string", "description": "The ID of the currently selected title" },
        "unlockedTitles": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked title IDs" },
        "selectedFrame": { "type": "string", "description": "The ID of the currently selected avatar frame" },
        "unlockedFrames": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked avatar frame IDs" },
        "selectedEntranceEffect": { "type": "string", "description": "The ID of the currently selected entrance effect" },
        "unlockedEntranceEffects": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked entrance effect IDs" },
        "rankPoints": { "type": "integer", "description": "The user's rank points" },
        "rankedWins": { "type": "integer", "description": "The user's ranked wins" },
        "rankedTotal": { "type": "integer", "description": "The user's total ranked games" },
        "lastRankedWinDate": { "type": "string", "description": "The date of the user's last ranked win" },
        "hgteFragments": { "type": "integer", "description": "Number of fragments for character HGTE" },
        "ttdFragments": { "type": "integer", "description": "Number of fragments for character TTD" }
      },
      "required": ["userId", "highScore", "totalGames", "achievements", "diamonds", "inventory", "unlockedCharacters"]
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "User daily check-in data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user" },
        "lastCheckIn": { "type": "string", "format": "date-time", "description": "The last time the user checked in" },
        "checkInCount": { "type": "integer", "description": "Number of consecutive days checked in" }
      },
      "required": ["userId", "lastCheckIn", "checkInCount"]
    },
    "Match": {
      "title": "Match",
      "description": "Multiplayer match data",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "player1": { 
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "score": { "type": "integer" },
            "status": { "type": "string", "enum": ["playing", "dead"] }
          },
          "required": ["uid", "name", "score", "status"]
        },
        "player2": { 
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "score": { "type": "integer" },
            "status": { "type": "string", "enum": ["playing", "dead"] }
          },
          "required": ["uid", "name", "score", "status"]
        },
        "winner": { "type": "string" }
      },
      "required": ["status", "createdAt", "player1"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "A game invitation from one user to another",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "toUid": { "type": "string" },
        "matchId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "fromName", "toUid", "matchId", "status", "createdAt"]
    },
    "Mail": {
      "title": "Mail",
      "description": "A system or user-to-user message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string", "description": "UID or 'all' for global announcements" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "sender": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "rewards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "amount": { "type": "integer" }
            }
          }
        }
      },
      "required": ["recipientId", "title", "content", "sender", "timestamp"]
    }
  },
  "firestore": {
    "/leaderboard/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Global high scores"
    },
    "/users/{userId}": {
      "schema": "UserStats",
      "description": "User-specific data"
    },
    "/checkIn/{userId}": {
      "schema": "CheckIn",
      "description": "User daily check-in data"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Multiplayer match data"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Game invitations"
    },
    "/mails/{mailId}": {
      "schema": "Mail",
      "description": "System and user messages"
    }
  }
}
