rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: checkIn
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - The unique ID of the user
    //   - lastCheckIn: timestamp (required) - The last time the user checked in
    //   - checkInCount: number (required) - Number of consecutive days checked in
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isPositiveNumber(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    function isValidList(listField, maxSize) {
      return request.resource.data[listField] is list && request.resource.data[listField].size() <= maxSize;
    }

    function isValidInventoryMap(mapData) {
      return mapData is map && 
             mapData.keys().hasOnly(['shield', 'magnet', 'doubleScore', 'dash']) &&
             (!('shield' in mapData) || mapData.shield is number && mapData.shield >= 0) &&
             (!('magnet' in mapData) || mapData.magnet is number && mapData.magnet >= 0) &&
             (!('doubleScore' in mapData) || mapData.doubleScore is number && mapData.doubleScore >= 0) &&
             (!('dash' in mapData) || mapData.dash is number && mapData.dash >= 0);
    }

    // Domain Validators
    
    function isValidLeaderboardEntry(data) {
      return hasRequiredFields(['userId', 'name', 'score', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'name', 'score', 'timestamp', 'avatarId']) &&
             validStringLength('userId', 1, 100) &&
             validStringLength('name', 1, 50) &&
             isPositiveNumber('score') &&
             (!('avatarId' in data) || validStringLength('avatarId', 1, 50)) &&
             data.timestamp is timestamp;
    }

    function isValidUserStats(data) {
      return hasRequiredFields(['userId', 'highScore', 'totalGames', 'diamonds', 'inventory', 'achievements']) &&
             hasOnlyAllowedFields(['userId', 'name', 'email', 'highScore', 'totalGames', 'diamonds', 'inventory', 'achievements', 'unlockedCharacters', 'avatarId', 'friends', 'hgteFragments']) &&
             validStringLength('userId', 1, 100) &&
             (!('name' in data) || validStringLength('name', 0, 100)) &&
             (!('email' in data) || validStringLength('email', 0, 100)) &&
             isPositiveNumber('highScore') &&
             isPositiveNumber('totalGames') &&
             isPositiveNumber('diamonds') &&
             isValidInventoryMap(data.inventory) &&
             isValidList('achievements', 100) &&
             (!('unlockedCharacters' in data) || isValidList('unlockedCharacters', 10)) &&
             (!('avatarId' in data) || validStringLength('avatarId', 1, 50)) &&
             (!('friends' in data) || isValidList('friends', 1000)) &&
             (!('hgteFragments' in data) || isPositiveNumber('hgteFragments'));
    }

    function isValidCheckIn(data) {
      return hasRequiredFields(['lastCheckIn', 'checkInCount']) &&
             hasOnlyAllowedFields(['userId', 'lastCheckIn', 'checkInCount']) &&
             (!('userId' in data) || validStringLength('userId', 1, 100)) &&
             data.lastCheckIn is timestamp &&
             isPositiveNumber('checkInCount');
    }

    function isValidPlayerObj(player) {
      return player is map &&
             player.keys().hasAll(['uid', 'name', 'score', 'status']) &&
             player.uid is string && player.uid.size() > 0 && player.uid.size() <= 100 &&
             player.name is string && player.name.size() <= 100 &&
             player.score is number && player.score >= 0 &&
             player.status in ['playing', 'dead'] &&
             (!('character' in player) || player.character is string);
    }

    function isValidMatch(data) {
      return hasRequiredFields(['status', 'createdAt', 'player1']) &&
             data.status in ['waiting', 'ready', 'playing', 'finished'] &&
             data.createdAt is timestamp &&
             isValidPlayerObj(data.player1) &&
             (!('player2' in data) || data.player2 == null || isValidPlayerObj(data.player2)) &&
             (!('winner' in data) || data.winner == null || data.winner is string) &&
             (!('roomType' in data) || data.roomType in ['random', 'private']) &&
             (!('roomId' in data) || data.roomId is string);
    }

    function isValidInvitation(data) {
      return hasRequiredFields(['fromUid', 'fromName', 'toUid', 'matchId', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['fromUid', 'fromName', 'toUid', 'matchId', 'status', 'createdAt']) &&
             data.fromUid is string && data.fromUid.size() > 0 &&
             data.fromName is string && data.fromName.size() > 0 &&
             data.toUid is string && data.toUid.size() > 0 &&
             data.matchId is string && data.matchId.size() > 0 &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard/{entryId} {
      // Anyone authenticated can read the leaderboard
      allow read: if isAuthenticated();
      // TEMPORARY: Allow any authenticated user to restore the leaderboard
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      // TEMPORARY: Allow any authenticated user to read all users for restoration
      allow read: if isAuthenticated();
      // Only the owner can create their own stats
      allow create: if isOwner(userId) && 
                       isValidUserStats(request.resource.data) && 
                       uidUnchanged();
      // Only the owner can update their own stats
      allow update: if isOwner(userId) && 
                       isValidUserStats(request.resource.data) && 
                       uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /checkIn/{userId} {
      // Only the owner can read their own check-in data
      allow read: if isOwner(userId);
      // Only the owner can create/update their own check-in data
      allow create, update: if isOwner(userId) && isValidCheckIn(request.resource.data);
      allow delete: if false;
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data) && request.resource.data.player1.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidMatch(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.player1.uid == request.auth.uid;
    }

    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidInvitation(request.resource.data) && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && isValidInvitation(request.resource.data) && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
